{
   "$schema":"https://specs.frictionlessdata.io/schemas/table-schema.json",
   "name":"efficacite-energetique-analyse-couts-avantages",
   "title":"Analyses coûts-avantages d'amélioration de l’efficacité énergétique",
   "description":"Spécification du fichier d'échange relatif aux analyses coûts-avantages évaluant la faisabilité économique d’amélioration de l’efficacité énergétique de l’approvisionnement en chaleur et en froid.",
   "keywords":[
      "transition-ecologique",
      "energie"
   ],
   "countryCode":"FR",
   "homepage":"https://github.com/datagouv/schema-efficacite-energetique-analyse-couts-avantages",
   "path":"https://github.com/datagouv/schema-efficacite-energetique-analyse-couts-avantages/raw/v0.1.0/schema.json",
   "licenses":[
      {
         "title":"Etalab Licence Ouverte 2.0",
         "name":"etalab-2.0",
         "path":"https://spdx.org/licenses/etalab-2.0.html"
      }
   ],
   "resources":[
      {
         "title":"Fichier valide (CSV)",
         "name":"exemple-valide-csv",
         "path":"https://github.com/datagouv/schema-efficacite-energetique-analyse-couts-avantages/raw/v0.1.0/exemple-valide.csv"
      }
   ],
   "sources":[
      {
         "title":"Arrêté du xxxx relatif aux analyses coûts-avantages évaluant la faisabilité économique d’amélioration de l’efficacité énergétique de l’approvisionnement en chaleur et en froid",
         "path":""
      }
   ],
   "created":"2026-05-13",
   "lastModified":"2026-05-13",
   "version":"v0.1.0",
   "contributors":[
      {
         "title": "Pierlou Ramade",
         "email": "pierlou.ramade@data.gouv.fr",
         "organisation": "DINUM",
         "role": "author"
      },
      {
         "title": "Johan Richer",
         "organisation": "DINUM",
         "role": "author"
      },
      {
         "title": "Angélique Lequai",
         "organisation": "DGEC",
         "role": "author"
      }
   ],
   "fields":[
      {
         "name":"siren_declarant",
         "description":"Numéro SIREN de la personne morale déclarante",
         "example":"130025265",
         "type":"string",
         "customCheck": "siren",
         "constraints":{
            "required":true
         }
      },
      {
         "name":"nom_declarant",
         "description":"Dénomination officielle de la personne morale",
         "example":"DINUM",
         "type":"string",
         "constraints":{
            "required":true
         }
      },
      {
         "name":"code_naf",
         "description":"Code d'activité principale exercée (code NAF)",
         "example":"47.72B",
         "type":"string",
         "constraints":{
            "required":true,
            "pattern": "^\\d\\d\\.\\d\\d[A-Z]$"
         }
      },
      {
         "name":"siret_projet",
         "description":"Numéro SIRET de l’établissement faisant l’objet de l’analyse coûts-avantages",
         "example":"13002526500013",
         "type":"string",
         "customCheck": "siret",
         "constraints":{
            "required":true
         }
      },
      {
         "name":"nom_projet",
         "description":"Dénomination de l’établissement faisant l’objet de l’analyse",
         "example":"DINUM",
         "type":"string",
         "constraints":{
            "required":true
         }
      },
      {
         "name":"code_commune",
         "description":"Code commune INSEE de l’établissement faisant l’objet de l’analyse",
         "example":"63113",
         "customCheck": "code-ommune-insee",
         "type":"string",
         "constraints":{
            "required":true
         }
      },
      {
         "name":"date_analyse",
         "description":"Date de réalisation de l’analyse, au format ISO 8601 AAAA-MM-DD.",
         "example":"2020-02-27",
         "type":"date",
         "constraints":{
            "required":true
         }
      },
      {
         "name":"chaleur_dispo",
         "description":"Quantité de chaleur disponible (en kWh/an)",
         "example":42,
         "type":"integer",
         "constraints":{
            "required":true
         }
      },
      {
         "name":"tmin",
         "description":"Température minimale de la chaleur disponible (en °C)",
         "example":42,
         "type":"integer",
         "constraints":{
            "required":true
         }
      },
      {
         "name":"tmax",
         "description":"Température maximale de la chaleur disponible (en °C)",
         "example":42,
         "type":"integer",
         "constraints":{
            "required":true
         }
      },
      {
         "name":"duree_exploitation",
         "description":"Durée d’exploitation de l’installation (en jours)",
         "example":42,
         "type":"integer",
         "constraints":{
            "required":true
         }
      }
   ]
}
